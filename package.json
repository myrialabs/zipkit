{
  "name": "@myrialabs/zipkit",
  "version": "0.0.11",
  "description": "Overkill compression for Node, Bun & the browser — ten codecs (gzip/deflate/zlib/zstd/lz4/snappy/brotli/lzma/bzip2/xz) plus ZIP (streaming + AES), tar, and 7z, in one tiny typed API over a single WebAssembly engine.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "bin": {
    "zipkit": "./dist/cli.js"
  },
  "files": [
    "dist",
    "engine/dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "scripts": {
    "build:engine": "bash engine/build.sh",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "bun test",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "keywords": [
    "compression",
    "gzip",
    "deflate",
    "zlib",
    "zstd",
    "brotli",
    "lz4",
    "snappy",
    "lzma",
    "bzip2",
    "xz",
    "zip",
    "tar",
    "7z",
    "encryption",
    "dictionary",
    "wasm",
    "bun",
    "browser",
    "fflate-alternative",
    "typescript"
  ],
  "author": "Myria Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myrialabs/zipkit.git"
  },
  "homepage": "https://github.com/myrialabs/zipkit#readme",
  "bugs": {
    "url": "https://github.com/myrialabs/zipkit/issues"
  },
  "devDependencies": {
    "@bokuweb/zstd-wasm": "^0.0.27",
    "@eslint/js": "^9.31.0",
    "@types/bun": "latest",
    "@types/node": "^22.10.0",
    "brotli-wasm": "^3.0.1",
    "eslint": "^9.31.0",
    "fflate": "^0.8.3",
    "globals": "^16.3.0",
    "jszip": "^3.10.1",
    "lz4js": "^0.2.0",
    "pako": "^2.1.0",
    "snappyjs": "^0.7.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.37.0"
  }
}
